<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/comfy_bg_dark"
    tools:context=".MainActivity">

    <!-- 统一的主界面包裹层 (内容 + 浮层) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <!-- Main Content Area -->
    <RelativeLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 使用可复用的 AppHeader 组件 -->
        <com.example.demo.view.AppHeader
            android:id="@+id/appHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Real-time Status Banner (Floating under header) -->
        <RelativeLayout
            android:id="@+id/statusBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/appHeader"
            android:background="@drawable/comfy_status_bg"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="10dp"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp"
            android:visibility="gone">

            <RelativeLayout
                android:id="@+id/statusTopRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/statusLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="正在排队中..."
                    android:textColor="@color/comfy_accent"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/statusPercentage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="11%"
                    android:textColor="#ACE12E"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />
            </RelativeLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_below="@id/statusTopRow"
                android:progressDrawable="@drawable/comfy_progress_bar" />

            <TextView
                android:id="@+id/btnCancelTask"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/progressBar"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="12dp"
                android:text="取消任务"
                android:textColor="#FF4D4D"
                android:textSize="12sp"
                android:paddingVertical="4dp"
                android:paddingHorizontal="8dp"
                android:background="@drawable/comfy_action_btn_bg"
                android:backgroundTint="#22FF4D4D" />
        </RelativeLayout>

        <ScrollView
            android:id="@+id/mainScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/statusBanner"
            android:layout_above="@+id/bottomBar"
            android:paddingHorizontal="20dp"
            android:clipToPadding="false"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="40dp">

                <View
                    android:id="@+id/heroSpacer"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"/>

                <!-- ========== 结果展示（动态显示）========== -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/resultCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#242424"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:cardMaxElevation="12dp"
                    android:visibility="gone">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <ImageView
                                android:id="@+id/resultImage"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:adjustViewBounds="true"
                                android:scaleType="fitCenter" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="最新生成"
                                android:textColor="@color/white"
                                android:background="#CC000000"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="6dp"
                                android:textSize="11sp"
                                android:layout_margin="16dp"
                                android:layout_alignParentStart="true"
                                android:layout_alignParentTop="true"
                                android:textStyle="bold"/>
                        </RelativeLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="#2A2A2A"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp">
                            <TextView
                                android:id="@+id/btnPreview"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:text="🔍 预览全图"
                                android:textColor="#DDDDDD"
                                android:textSize="13sp"
                                android:gravity="center"
                                android:background="@drawable/comfy_action_btn_bg"
                                android:backgroundTint="#33FFFFFF"/>
                            <TextView
                                android:layout_width="1dp"
                                android:layout_height="24dp"
                                android:background="#333333"/>
                            <TextView
                                android:id="@+id/btnDownload"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:text="保存至相册"
                                android:textColor="#DDDDDD"
                                android:textSize="13sp"
                                android:gravity="center"
                                android:background="@drawable/comfy_action_btn_bg"
                                android:backgroundTint="#33FFFFFF"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ========== 核心操作区：提示词构建（高亮显示）========== -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardBackgroundColor="#252525"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp"
                    app:strokeColor="#33ACE12E"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <!-- 卡片标题 -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="20dp">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="提示词构建"
                                    android:textColor="@color/white"
                                    android:textStyle="bold"
                                    android:textSize="18sp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="描述你脑海中的画面"
                                    android:textColor="#666666"
                                    android:textSize="12sp"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                            <!-- 步骤标识 -->
                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_alignParentEnd="true"
                                android:background="@drawable/circle_step_bg"
                                android:text="1"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:gravity="center"/>
                        </RelativeLayout>

                        <!-- Positive Section -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/comfy_label_bg"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="正向提示词"
                                android:textColor="#ACE12E"
                                android:textSize="13sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="必填 · 核心"
                                android:textColor="#ACE12E"
                                android:textSize="10sp"
                                android:background="@drawable/comfy_tag_recommend_bg"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="3dp"
                                android:layout_marginStart="10dp"/>
                        </LinearLayout>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="20dp">

                        <EditText
                            android:id="@+id/etPromptPositive"
                            android:layout_width="match_parent"
                            android:layout_height="150dp"
                            android:background="@drawable/comfy_edit_bg_focused"
                            android:gravity="top"
                            android:padding="16dp"
                            android:textColor="@color/white"
                            android:hint="示例：一只可爱的橘猫，坐在窗台上，阳光洒落，毛茸茸的细节，电影级画质，柔和光效"
                            android:textColorHint="#444444"
                            android:textSize="14sp" />

                        <ImageButton
                            android:id="@+id/btnOptimizePrompt"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true"
                            android:layout_marginEnd="6dp"
                            android:layout_marginBottom="6dp"
                            android:background="@android:color/transparent"
                            android:src="@drawable/ic_ai_magic"
                            android:scaleType="fitCenter"
                            android:contentDescription="AI 优化提示词"/>

                        </RelativeLayout>

                        <!-- Negative Section -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/comfy_label_bg"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="负向提示词"
                                android:textColor="#999999"
                                android:textSize="13sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="可选 · 过滤"
                                android:textColor="#FF4D4F"
                                android:textSize="10sp"
                                android:background="@drawable/comfy_tag_filter_bg"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="3dp"
                                android:layout_marginStart="10dp"/>
                        </LinearLayout>

                        <EditText
                            android:id="@+id/etPromptNegative"
                            android:layout_width="match_parent"
                            android:layout_height="90dp"
                            android:background="@drawable/comfy_edit_bg"
                            android:gravity="top"
                            android:padding="16dp"
                            android:textColor="@color/white"
                            android:hint="输入不希望出现的内容（低质量、模糊、变形等），留空则使用默认过滤"
                            android:textColorHint="#444444"
                            android:textSize="14sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ========== 快速设置区（常用参数）========== -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#1F1F1F"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- 标题栏 -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="快速设置"
                                    android:textColor="@color/white"
                                    android:textStyle="bold"
                                    android:textSize="16sp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="常用参数一键配置"
                                    android:textColor="#555555"
                                    android:textSize="11sp"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>
                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_alignParentEnd="true"
                                android:background="@drawable/circle_step_bg_secondary"
                                android:text="2"
                                android:textColor="#AAAAAA"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:gravity="center"/>
                        </RelativeLayout>

                        <!-- 分辨率预设 -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="图片尺寸"
                            android:textColor="#888888"
                            android:textSize="13sp"
                            android:layout_marginBottom="10dp"/>

                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:scrollbars="none"
                            android:layout_marginBottom="16dp">
                            <LinearLayout
                                android:id="@+id/presetRow"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <TextView
                                    android:id="@+id/preset512"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="512×512"
                                    android:textColor="#777777"
                                    android:background="@drawable/comfy_preset_btn"
                                    android:paddingHorizontal="16dp"
                                    android:paddingVertical="10dp"
                                    android:layout_marginEnd="10dp"
                                    android:textSize="13sp"/>
                                <TextView
                                    android:id="@+id/preset1K"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="1K 标准 ✓"
                                    android:textColor="@color/black"
                                    android:background="@drawable/comfy_preset_btn_selected"
                                    android:paddingHorizontal="16dp"
                                    android:paddingVertical="10dp"
                                    android:layout_marginEnd="10dp"
                                    android:textSize="13sp"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:id="@+id/preset720p"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="720P"
                                    android:textColor="#777777"
                                    android:background="@drawable/comfy_preset_btn"
                                    android:paddingHorizontal="16dp"
                                    android:paddingVertical="10dp"
                                    android:layout_marginEnd="10dp"
                                    android:textSize="13sp"/>
                                <TextView
                                    android:id="@+id/preset1080p"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="1080P"
                                    android:textColor="#777777"
                                    android:background="@drawable/comfy_preset_btn"
                                    android:paddingHorizontal="16dp"
                                    android:paddingVertical="10dp"
                                    android:layout_marginEnd="10dp"
                                    android:textSize="13sp"/>
                                <TextView
                                    android:id="@+id/preset4K"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="4K 超清"
                                    android:textColor="#777777"
                                    android:background="@drawable/comfy_preset_btn"
                                    android:paddingHorizontal="16dp"
                                    android:paddingVertical="10dp"
                                    android:layout_marginEnd="10dp"
                                    android:textSize="13sp"/>
                            </LinearLayout>
                        </HorizontalScrollView>

                        <!-- 自定义尺寸 -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/comfy_custom_size_bg"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="12dp"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:text="自定义"
                                android:textColor="#666666"
                                android:textSize="13sp"/>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="@drawable/comfy_input_bg_rounded"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="8dp">
                                <EditText
                                    android:id="@+id/etWidth"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@null"
                                    android:text="1024"
                                    android:textColor="@color/white"
                                    android:gravity="center"
                                    android:inputType="number"
                                    android:textSize="15sp"
                                    android:minWidth="50dp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="×"
                                    android:textColor="#555555"
                                    android:layout_marginHorizontal="10dp"
                                    android:textSize="16sp"/>
                                <EditText
                                    android:id="@+id/etHeight"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@null"
                                    android:text="1024"
                                    android:textColor="@color/white"
                                    android:gravity="center"
                                    android:inputType="number"
                                    android:textSize="15sp"
                                    android:minWidth="50dp"/>
                            </LinearLayout>
                        </RelativeLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ========== 高级参数（可折叠）========== -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- 折叠标题栏 -->
                        <RelativeLayout
                            android:id="@+id/advancedHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="20dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="高级参数"
                                    android:textColor="#BBBBBB"
                                    android:textStyle="bold"
                                    android:textSize="16sp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="步数 / CFG / 种子"
                                    android:textColor="#555555"
                                    android:textSize="11sp"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>

                            <ImageView
                                android:id="@+id/advancedArrow"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_arrow_down"/>
                        </RelativeLayout>

                        <!-- 可折叠内容区 -->
                        <LinearLayout
                            android:id="@+id/advancedContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingHorizontal="20dp"
                            android:paddingBottom="20dp"
                            android:visibility="gone">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#222222"
                                android:layout_marginBottom="16dp"/>

                            <!-- Steps & CFG 并排 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="16dp">
                                
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:paddingEnd="12dp">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="采样步数"
                                        android:textColor="#777777"
                                        android:textSize="12sp"/>
                                    <EditText
                                        android:id="@+id/etSteps"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="6dp"
                                        android:text="9"
                                        android:background="@null"
                                        android:textColor="@color/white"
                                        android:inputType="number"
                                        android:textStyle="bold"
                                        android:textSize="22sp"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="推荐: 9-30"
                                        android:textColor="#444444"
                                        android:textSize="10sp"
                                        android:layout_marginTop="2dp"/>
                                </LinearLayout>

                                <View
                                    android:layout_width="1dp"
                                    android:layout_height="match_parent"
                                    android:background="#222222"/>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:paddingStart="12dp">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="引导系数 CFG"
                                        android:textColor="#777777"
                                        android:textSize="12sp"/>
                                    <EditText
                                        android:id="@+id/etCFG"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="6dp"
                                        android:text="1"
                                        android:background="@null"
                                        android:textColor="@color/white"
                                        android:inputType="numberDecimal"
                                        android:textStyle="bold"
                                        android:textSize="22sp"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="推荐: 1-7"
                                        android:textColor="#444444"
                                        android:textSize="10sp"
                                        android:layout_marginTop="2dp"/>
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Seed 输入 -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="随机种子 (Seed)"
                                android:textColor="#777777"
                                android:textSize="12sp"
                                android:layout_marginBottom="8dp"/>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="@drawable/comfy_edit_bg"
                                android:paddingHorizontal="4dp">
                                <EditText
                                    android:id="@+id/etSeed"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:text="0"
                                    android:textColor="#ACE12E"
                                    android:background="@null"
                                    android:paddingHorizontal="12dp"
                                    android:inputType="number"
                                    android:textSize="14sp"
                                    android:hint="0 = 随机"
                                    android:textColorHint="#444444"/>
                                <ImageButton
                                    android:id="@+id/btnRandomSeed"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:src="@android:drawable/ic_menu_rotate"
                                    app:tint="#666666"/>
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="相同种子 + 相同参数 = 相同结果"
                                android:textColor="#444444"
                                android:textSize="11sp"
                                android:layout_marginTop="8dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 底部安全间距 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="80dp"/>

            </LinearLayout>
        </ScrollView>

        <!-- Bottom Bar - 固定底部生成按钮 -->
        <RelativeLayout
            android:id="@+id/bottomBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:background="@drawable/comfy_bottom_bg_enhanced"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="28dp"
            android:elevation="12dp">

            <!-- 快速提示 -->
            <TextView
                android:id="@+id/generateHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_above="@+id/btnGenerate"
                android:layout_marginBottom="10dp"
                android:text="完成设置后点击下方按钮开始生成"
                android:textColor="#666666"
                android:textSize="12sp"
                android:gravity="center"
                android:visibility="visible"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenerate"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:backgroundTint="#ACE12E"
                android:text="开始生成"
                android:textColor="@color/black"
                android:textSize="17sp"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:cornerRadius="18dp"
                app:rippleColor="#40000000"
                app:elevation="6dp"
                app:strokeWidth="0dp"
                app:iconGravity="textStart"
                app:iconPadding="8dp"/>
        </RelativeLayout>
    </RelativeLayout>

    <!-- Overlay Layer (API Setting & Syncing) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Fullscreen Image Preview Overlay -->
        <RelativeLayout
            android:id="@+id/previewOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FF000000"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">
        
            <com.github.chrisbanes.photoview.PhotoView
                android:id="@+id/ivFullscreenPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_centerInParent="true" />
        
            <ImageView
                android:id="@+id/btnClosePreview"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="32dp"
                android:layout_marginEnd="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/white" />
        
            <!-- 新增设为壁纸按钮 -->
            <Button
                android:id="@+id/btnSetWallpaper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="设为壁纸"
                android:textColor="@android:color/white"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_alignParentEnd="true"
                android:layout_below="@id/btnClosePreview"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnSaveImage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="保存图片"
                android:textColor="@android:color/white"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_alignParentEnd="true"
                android:layout_below="@id/btnSetWallpaper"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                android:visibility="gone" />
        </RelativeLayout>

    </FrameLayout>

    </FrameLayout>

</FrameLayout>
