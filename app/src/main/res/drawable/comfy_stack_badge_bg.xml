<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="2dp">
        <shape>
            <solid android:color="#4D000000" />
            <corners android:radius="13dp" />
        </shape>
    </item>
    <item>
        <shape>
            <stroke android:width="1dp" android:color="#40FFFFFF" />
            <corners android:radius="13dp" />
        </shape>
    </item>
    <item android:bottom="0.5dp" android:left="0.5dp" android:right="0.5dp" android:top="0.5dp">
        <shape>
            <gradient
                android:angle="135"
                android:startColor="#CC333333"
                android:endColor="#E6000000" />
            <corners android:radius="12.5dp" />
        </shape>
    </item>
    <item android:bottom="14dp" android:left="4dp" android:right="4dp" android:top="2dp">
        <shape>
            <solid android:color="#1AFFFFFF" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</layer-list>
