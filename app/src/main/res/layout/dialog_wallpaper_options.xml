<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/comfy_dialog_bg"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="壁纸显示方式"
        android:textColor="@color/comfy_text_sub"
        android:textSize="13sp"
        android:layout_marginBottom="16dp" />

    <RadioGroup
        android:id="@+id/rgWallpaperMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/comfy_input_bg_rounded"
        android:padding="4dp"
        android:layout_marginBottom="20dp">

        <RadioButton
            android:id="@+id/rbCrop"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:button="@null"
            android:checked="true"
            android:gravity="center"
            android:text="裁剪适配"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:background="@drawable/comfy_preset_selected_bg" />

        <RadioButton
            android:id="@+id/rbTile"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:button="@null"
            android:gravity="center"
            android:text="平铺"
            android:textColor="#777777"
            android:textSize="13sp"
            android:background="@android:color/transparent" />

        <RadioButton
            android:id="@+id/rbCenter"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:button="@null"
            android:gravity="center"
            android:text="居中"
            android:textColor="#777777"
            android:textSize="13sp"
            android:background="@android:color/transparent" />
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="效果预览"
        android:textColor="@color/comfy_text_sub"
        android:textSize="13sp"
        android:layout_marginBottom="12dp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#1AFFFFFF"
        app:cardElevation="0dp"
        android:layout_marginBottom="24dp">
        
        <ImageView
            android:id="@+id/ivWallpaperPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerInside"
            android:adjustViewBounds="true"
            android:contentDescription="壁纸预览" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        
        <Button
            android:id="@+id/btnApplyWallpaper"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="设为手机壁纸"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:background="@drawable/comfy_preset_selected_bg" />
    </LinearLayout>

</LinearLayout>